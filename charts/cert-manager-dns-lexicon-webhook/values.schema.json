{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "cert-manager DNS Lexicon Webhook Helm Chart Values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "enabled": {
      "type": "boolean",
      "description": "Enable this chart (used by umbrella chart)"
    },
    "groupName": {
      "type": "string",
      "description": "ACME DNS01 solver group name (e.g. acme.mycompany.com). Must be unique and referenced in each Issuer's webhook stanza."
    },
    "replicaCount": {
      "type": "integer",
      "description": "Number of replicas",
      "minimum": 1
    },
    "namespaceOverride": {
      "type": "string",
      "description": "Override the namespace where resources are deployed (defaults to release namespace)"
    },
    "certManager": {
      "type": "object",
      "description": "cert-manager reference configuration",
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "type": "string",
          "description": "Namespace where cert-manager is installed"
        },
        "serviceAccountName": {
          "type": "string",
          "description": "cert-manager service account name"
        }
      }
    },
    "image": {
      "type": "object",
      "description": "Container image configuration",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "description": "Container image repository"
        },
        "tag": {
          "type": "string",
          "description": "Image tag"
        },
        "digest": {
          "type": "string",
          "description": "Image digest (sha256:...)",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "pullPolicy": {
          "type": "string",
          "description": "Image pull policy",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "nameOverride": {
      "type": "string",
      "description": "Override the chart name"
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full release name"
    },
    "service": {
      "type": "object",
      "description": "Service configuration",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "Service type",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer",
          "description": "Service port number"
        }
      }
    },
    "resources": {
      "$ref": "#/$defs/resources"
    },
    "nodeSelector": {
      "type": "object",
      "description": "Node selector for pod assignment",
      "additionalProperties": {
        "type": "string"
      }
    },
    "tolerations": {
      "type": "array",
      "description": "Tolerations for pod assignment",
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object",
      "description": "Affinity rules for pod assignment"
    }
  },
  "$defs": {
    "resources": {
      "type": "object",
      "description": "CPU/memory resource requests and limits",
      "additionalProperties": false,
      "properties": {
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          }
        },
        "requests": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
