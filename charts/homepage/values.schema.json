{
  "$ref": "#/definitions/Values",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "Values": {
      "additionalProperties": false,
      "properties": {
        "affinity": {
          "description": "Affinity rules for pod assignment",
          "type": "object"
        },
        "clusterrole": {
          "additionalProperties": false,
          "description": "ClusterRole for Kubernetes API access",
          "properties": {
            "enable": {
              "description": "Enable ClusterRole creation",
              "type": "boolean"
            },
            "rules": {
              "description": "RBAC policy rules",
              "items": {
                "additionalProperties": false,
                "properties": {
                  "apiGroups": {
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  },
                  "resources": {
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  },
                  "verbs": {
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  }
                },
                "type": "object"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "configMap": {
          "additionalProperties": false,
          "description": "ConfigMap for Homepage configuration files",
          "properties": {
            "data": {
              "additionalProperties": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "not": {}
                  }
                ]
              },
              "description": "ConfigMap data entries (YAML config files as strings)",
              "properties": {
                "allowedHosts": {
                  "description": "Allowed hosts for Homepage (required)",
                  "type": "string"
                },
                "bookmarks.yaml": {
                  "type": "string"
                },
                "custom.css": {
                  "type": "string"
                },
                "custom.js": {
                  "type": "string"
                },
                "docker.yaml": {
                  "type": "string"
                },
                "kubernetes.yaml": {
                  "type": "string"
                },
                "services.yaml": {
                  "type": "string"
                },
                "settings.yaml": {
                  "type": "string"
                },
                "widgets.yaml": {
                  "type": "string"
                }
              },
              "type": "object"
            },
            "enable": {
              "description": "Enable ConfigMap creation",
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "dnsPolicy": {
          "description": "DNS policy for the pod",
          "enum": [
            "ClusterFirst",
            "Default",
            "ClusterFirstWithHostNet",
            "None"
          ],
          "type": "string"
        },
        "enableServiceLinks": {
          "description": "Enable service links in the pod",
          "type": "boolean"
        },
        "enabled": {
          "description": "Enable/disable this chart (used by platform condition)",
          "type": "boolean"
        },
        "env": {
          "description": "Environment variables for the container",
          "items": {
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            },
            "required": [
              "name"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "fullnameOverride": {
          "description": "Override the full release name",
          "type": "string"
        },
        "global": {
          "description": "Injected by Helm for sub-chart coordination",
          "type": "object"
        },
        "image": {
          "additionalProperties": false,
          "description": "Container image configuration",
          "properties": {
            "pullPolicy": {
              "description": "Image pull policy",
              "enum": [
                "Always",
                "IfNotPresent",
                "Never"
              ],
              "type": "string"
            },
            "repository": {
              "description": "Container image repository",
              "type": "string"
            },
            "tag": {
              "description": "Overrides the image tag whose default is the chart appVersion",
              "type": "string"
            }
          },
          "type": "object"
        },
        "ingress": {
          "additionalProperties": false,
          "description": "Ingress configuration",
          "properties": {
            "annotations": {
              "additionalProperties": {
                "type": "string"
              },
              "description": "Ingress annotations",
              "type": "object"
            },
            "className": {
              "description": "Ingress class name",
              "type": "string"
            },
            "enabled": {
              "description": "Enable ingress",
              "type": "boolean"
            },
            "hosts": {
              "description": "Ingress host rules",
              "items": {
                "additionalProperties": false,
                "properties": {
                  "host": {
                    "type": "string"
                  },
                  "paths": {
                    "items": {
                      "additionalProperties": false,
                      "properties": {
                        "path": {
                          "type": "string"
                        },
                        "pathType": {
                          "enum": [
                            "Prefix",
                            "Exact",
                            "ImplementationSpecific"
                          ],
                          "type": "string"
                        }
                      },
                      "type": "object"
                    },
                    "type": "array"
                  }
                },
                "type": "object"
              },
              "type": "array"
            },
            "tls": {
              "description": "Ingress TLS configuration",
              "items": {
                "additionalProperties": false,
                "properties": {
                  "hosts": {
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  },
                  "secretName": {
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "livenessProbe": {
          "additionalProperties": false,
          "description": "Liveness probe configuration",
          "properties": {
            "failureThreshold": {
              "type": "integer"
            },
            "httpGet": {
              "additionalProperties": false,
              "properties": {
                "path": {
                  "type": "string"
                },
                "port": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "integer"
                    }
                  ]
                }
              },
              "type": "object"
            },
            "initialDelaySeconds": {
              "type": "integer"
            },
            "periodSeconds": {
              "type": "integer"
            },
            "timeoutSeconds": {
              "type": "integer"
            }
          },
          "type": "object"
        },
        "nameOverride": {
          "description": "Override the chart name",
          "type": "string"
        },
        "namespaceOverride": {
          "description": "Override the deployment namespace",
          "type": "string"
        },
        "nodeSelector": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Node selector for pod assignment",
          "type": "object"
        },
        "podAnnotations": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Annotations for the pod",
          "type": "object"
        },
        "podLabels": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Labels for the pod",
          "type": "object"
        },
        "podSecurityContext": {
          "description": "Pod security context",
          "type": "object"
        },
        "readinessProbe": {
          "additionalProperties": false,
          "description": "Readiness probe configuration",
          "properties": {
            "failureThreshold": {
              "type": "integer"
            },
            "httpGet": {
              "additionalProperties": false,
              "properties": {
                "path": {
                  "type": "string"
                },
                "port": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "integer"
                    }
                  ]
                }
              },
              "type": "object"
            },
            "initialDelaySeconds": {
              "type": "integer"
            },
            "periodSeconds": {
              "type": "integer"
            },
            "timeoutSeconds": {
              "type": "integer"
            }
          },
          "type": "object"
        },
        "replicaCount": {
          "description": "Number of replicas",
          "minimum": 1,
          "type": "integer"
        },
        "resources": {
          "additionalProperties": false,
          "description": "CPU/memory resource requests and limits",
          "properties": {
            "limits": {
              "additionalProperties": false,
              "description": "CPU/memory resource requests and limits",
              "properties": {
                "cpu": {
                  "type": "string"
                },
                "memory": {
                  "type": "string"
                }
              },
              "type": "object"
            },
            "requests": {
              "additionalProperties": false,
              "properties": {
                "cpu": {
                  "type": "string"
                },
                "memory": {
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          "type": "object"
        },
        "revisionHistoryLimit": {
          "description": "Number of old ReplicaSets to retain",
          "minimum": 0,
          "type": "integer"
        },
        "secret": {
          "additionalProperties": false,
          "description": "Secret configuration",
          "properties": {
            "annotations": {
              "additionalProperties": {
                "type": "string"
              },
              "description": "Annotations for the secret",
              "type": "object"
            }
          },
          "type": "object"
        },
        "securityContext": {
          "description": "Container security context",
          "type": "object"
        },
        "service": {
          "additionalProperties": false,
          "description": "Service configuration",
          "properties": {
            "port": {
              "description": "Service port number",
              "type": "integer"
            },
            "type": {
              "description": "Service type",
              "enum": [
                "ClusterIP",
                "NodePort",
                "LoadBalancer",
                "ExternalName"
              ],
              "type": "string"
            }
          },
          "type": "object"
        },
        "serviceAccount": {
          "additionalProperties": false,
          "description": "Service account configuration",
          "properties": {
            "annotations": {
              "additionalProperties": {
                "type": "string"
              },
              "description": "Annotations for the service account",
              "type": "object"
            },
            "automount": {
              "description": "Automatically mount API credentials",
              "type": "boolean"
            },
            "create": {
              "description": "Create a service account",
              "type": "boolean"
            },
            "name": {
              "description": "Service account name (generated from fullname if empty)",
              "type": "string"
            }
          },
          "type": "object"
        },
        "tolerations": {
          "description": "Tolerations for pod assignment",
          "items": {
            "type": "object"
          },
          "type": "array"
        },
        "volumeMounts": {
          "description": "Additional volume mounts for the container",
          "items": {
            "additionalProperties": false,
            "properties": {
              "mountPath": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "subPath": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "type": "array"
        },
        "volumes": {
          "description": "Additional volumes for the deployment",
          "items": {
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    }
  }
}