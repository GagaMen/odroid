                },
                "enabled": {
                  "type": "boolean"
                },
                "interval": {
                  "type": "string"
                },
                "metricRelabelings": {
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "relabelings": {
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "tlsConfig": {
                  "type": "object"
                }
              },
              "type": "object"
            }
