                },
                "extraAnnotations": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object"
                },
                "extraContainers": {
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "extraLabels": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object"
                },
                "hostNetwork": {
                  "description": "Configures Pods to use the host network",
                  "type": "boolean"
                },
                "hostPID": {
                  "description": "Configures Pods to use the host PID namespace",
                  "type": "boolean"
                },
                "initContainers": {
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "minReadySeconds": {
                  "description": "Minimum ready seconds",
                  "type": "integer"
                },
                "nodeSelector": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object"
                },
                "parallelRollout": {
                  "description": "Whether to deploy pods in parallel (statefulset only)",
                  "type": "boolean"
                },
                "podAnnotations": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object"
                },
                "podDisruptionBudget": {
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "description": "Whether to create a PodDisruptionBudget",
                      "type": "boolean"
                    },
                    "maxUnavailable": {
                      "type": [
                        "number",
                        "string"
                      ]
                    },
                    "minAvailable": {
                      "type": [
                        "number",
                        "string"
                      ]
                    }
                  },
                  "type": "object"
                },
                "podLabels": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object"
                },
                "priorityClassName": {
                  "type": "string"
                },
                "replicas": {
                  "description": "Number of replicas",
                  "minimum": 1,
                  "type": "integer"
                },
                "terminationGracePeriodSeconds": {
                  "description": "Termination grace period in seconds",
                  "type": "integer"
                },
                "tolerations": {
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "topologySpreadConstraints": {
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "type": {
                  "description": "Controller type",
                  "enum": [
                    "daemonset",
                    "deployment",
                    "statefulset"
                  ],
                  "type": "string"
                },
                "updateStrategy": {
                  "type": "object"
                },
                "volumeClaimTemplates": {
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "volumes": {
                  "additionalProperties": false,
                  "properties": {
                    "extra": {
                      "items": {
                        "type": "object"
                      },
                      "type": "array"
                    }
                  },
                  "type": "object"
                }
              },
              "type": "object"
            },
            "crds": {
              "additionalProperties": false,
              "properties": {
                "create": {
                  "description": "Whether to install CRDs for monitoring",
                  "type": "boolean"
                },
                "global": {
                  "description": "Helm global values propagated by Helm into sub-chart sections",
                  "type": "object"
                }
              },
              "type": "object"
            },
            "extraObjects": {
              "description": "Extra Kubernetes manifests to deploy",
              "items": {
                "type": "object"
              },
              "type": "array"
            },
            "fullnameOverride": {
              "type": "string"
            },
            "global": {
              "additionalProperties": false,
              "properties": {
                "image": {
                  "additionalProperties": false,
                  "properties": {
                    "pullSecrets": {
                      "description": "Global image pull secrets",
                      "items": {
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "registry": {
                      "description": "Global image registry override",
                      "type": "string"
                    }
                  },
                  "type": "object"
                },
                "podSecurityContext": {
                  "description": "Security context to apply to the Grafana Alloy pod",
                  "type": "object"
                }
              },
              "type": "object"
            },
            "image": {
              "additionalProperties": false,
              "properties": {
                "digest": {
                  "description": "SHA256 digest override",
                  "type": "string"
                },
                "pullPolicy": {
                  "enum": [
                    "Always",
                    "IfNotPresent",
                    "Never"
                  ],
                  "type": "string"
                },
                "pullSecrets": {
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "registry": {
                  "type": "string"
                },
                "repository": {
                  "type": "string"
                },
                "tag": {
                  "type": "string"
                }
              },
              "type": "object"
            },
            "ingress": {
              "additionalProperties": false,
              "properties": {
                "annotations": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object"
                },
                "enabled": {
                  "description": "Enables ingress for Alloy (Faro port)",
                  "type": "boolean"
                },
                "extraPaths": {
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "faroPort": {
                  "type": "integer"
                },
                "hosts": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "ingressClassName": {
                  "type": "string"
                },
                "labels": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object"
                },
                "path": {
                  "type": "string"
                },
                "pathType": {
                  "type": "string"
                },
                "tls": {
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                }
              },
              "type": "object"
            },
            "nameOverride": {
              "type": "string"
            },
            "namespaceOverride": {
              "description": "Namespace override for the Alloy deployment",
              "type": "string"
            },
            "networkPolicy": {
              "additionalProperties": false,
              "properties": {
                "egress": {
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "enabled": {
                  "type": "boolean"
                },
                "flavor": {
                  "type": "string"
                },
                "ingress": {
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "policyTypes": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                }
              },
              "type": "object"
            },
            "rbac": {
              "additionalProperties": false,
              "description": "RBAC configuration",
              "properties": {
                "clusterRules": {
                  "description": "Rules for the ClusterRole objects",
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "create": {
                  "description": "Whether to create RBAC resources for Alloy",
                  "type": "boolean"
                },
                "namespaces": {
                  "description": "Namespaces to create Roles/RoleBindings in instead of ClusterRoles",
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "rules": {
                  "description": "Rules for the ClusterRole or Role objects",
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                }
              },
              "type": "object"
            },
            "service": {
              "additionalProperties": false,
              "properties": {
                "annotations": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object"
                },
                "clusterIP": {
                  "type": "string"
                },
                "enabled": {
                  "description": "Creates a Service for the controller's pods",
                  "type": "boolean"
                },
                "internalTrafficPolicy": {
                  "type": "string"
                },
                "nodePort": {
                  "type": "integer"
                },
                "type": {
                  "type": "string"
                }
              },
              "type": "object"
            },
            "serviceAccount": {
              "additionalProperties": false,
              "description": "Service account configuration",
              "properties": {
                "additionalLabels": {
                  "additionalProperties": {
                    "type": "string"
