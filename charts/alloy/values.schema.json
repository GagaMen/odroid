{
  "$ref": "#/definitions/Values",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "Values": {
      "additionalProperties": false,
      "properties": {
        "alloy": {
          "additionalProperties": false,
          "description": "Grafana Alloy upstream chart values (see https://github.com/grafana/alloy/tree/main/operations/helm/charts/alloy)",
          "properties": {
            "alloy": {
              "additionalProperties": false,
              "description": "Alloy application configuration",
              "properties": {
                "clustering": {
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "description": "Deploy Alloy in a cluster to allow for load distribution",
                      "type": "boolean"
                    },
                    "name": {
                      "description": "Name for the Alloy cluster",
                      "type": "string"
                    },
                    "portName": {
                      "description": "Name for the port used for clustering",
                      "type": "string"
                    }
                  },
                  "type": "object"
                },
                "configMap": {
                  "additionalProperties": false,
                  "properties": {
                    "content": {
                      "description": "Alloy pipeline configuration (River format)",
                      "type": "string"
                    },
                    "create": {
                      "description": "Create a ConfigMap for Alloy configuration",
                      "type": "boolean"
                    },
                    "key": {
                      "description": "ConfigMap key for the config file",
                      "type": "string"
                    },
                    "name": {
                      "description": "Name of existing ConfigMap to use (when create is false)",
                      "type": "string"
                    }
                  },
                  "type": "object"
                },
                "enableHttpServerPort": {
                  "description": "Enables Grafana Alloy container's http server port",
                  "type": "boolean"
                },
                "enableReporting": {
                  "description": "Enables sending Grafana Labs anonymous usage stats",
                  "type": "boolean"
                },
                "envFrom": {
                  "description": "Maps all the keys on a ConfigMap or Secret as environment variables",
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "extraArgs": {
                  "description": "Extra args to pass to `alloy run`",
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "extraEnv": {
                  "description": "Extra environment variables to pass to the Alloy container",
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "extraPorts": {
                  "description": "Extra ports to expose on the Alloy container",
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "hostAliases": {
                  "description": "Host aliases to add to the Alloy container",
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "initialDelaySeconds": {
                  "description": "Initial delay for readiness probe",
                  "type": "integer"
                },
                "lifecycle": {
                  "description": "Lifecycle hooks for the Grafana Alloy container",
                  "type": "object"
                },
                "listenAddr": {
                  "description": "Address to listen for traffic on",
                  "type": "string"
                },
                "listenPort": {
                  "description": "Port to listen for traffic on",
                  "type": "integer"
                },
                "listenScheme": {
                  "description": "Scheme for readiness probes. Set to \"HTTPS\" if TLS is enabled",
                  "type": "string"
                },
                "livenessProbe": {
                  "description": "Liveness probe for the Grafana Alloy container",
                  "type": "object"
                },
                "mounts": {
                  "additionalProperties": false,
                  "description": "Extra mounts for the Alloy container",
                  "properties": {
                    "dockercontainers": {
                      "description": "Mount /var/lib/docker/containers from the host into the container for log collection",
                      "type": "boolean"
                    },
                    "extra": {
                      "description": "Extra volume mounts to add into the Grafana Alloy container",
                      "items": {
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "varlog": {
                      "description": "Mount /var/log from the host into the container for log collection",
                      "type": "boolean"
                    }
                  },
                  "type": "object"
                },
                "resources": {
                  "type": "object"
                },
                "securityContext": {
                  "description": "Security context to apply to the Grafana Alloy container",
                  "type": "object"
                },
                "stabilityLevel": {
                  "description": "Minimum stability level of components and behavior to enable",
                  "enum": [
                    "experimental",
                    "public-preview",
                    "generally-available"
                  ],
                  "type": "string"
                },
                "storagePath": {
                  "description": "Path to where Grafana Alloy stores data",
                  "type": "string"
                },
                "timeoutSeconds": {
                  "description": "Timeout for readiness probe",
                  "type": "integer"
                },
                "uiPathPrefix": {
                  "description": "Base path where the UI is exposed",
                  "type": "string"
                }
              },
              "type": "object"
            },
            "configReloader": {
              "additionalProperties": false,
              "properties": {
                "customArgs": {
                  "description": "Override the args passed to the container",
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "enabled": {
                  "description": "Enables automatically reloading when the Alloy config changes",
                  "type": "boolean"
                },
                "image": {
                  "additionalProperties": false,
                  "properties": {
                    "digest": {
                      "description": "SHA256 digest override",
                      "type": "string"
                    },
                    "registry": {
                      "type": "string"
                    },
                    "repository": {
                      "type": "string"
                    },
                    "tag": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                },
                "resources": {
                  "type": "object"
                },
                "securityContext": {
                  "type": "object"
                }
              },
              "type": "object"
            },
            "controller": {
              "additionalProperties": false,
              "description": "Controller configuration",
              "properties": {
                "affinity": {
                  "type": "object"
                },
                "autoscaling": {
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "deprecated": "Use horizontal instead",
                      "type": "boolean"
                    },
                    "horizontal": {
                      "additionalProperties": false,
                      "properties": {
                        "enabled": {
                          "type": "boolean"
                        },
                        "maxReplicas": {
                          "minimum": 1,
                          "type": "integer"
                        },
                        "minReplicas": {
                          "minimum": 1,
                          "type": "integer"
                        },
                        "scaleDown": {
                          "additionalProperties": false,
                          "properties": {
                            "policies": {
                              "items": {
                                "type": "object"
                              },
                              "type": "array"
                            },
                            "selectPolicy": {
                              "type": "string"
                            },
                            "stabilizationWindowSeconds": {
                              "type": "integer"
                            }
                          },
                          "type": "object"
                        },
                        "scaleUp": {
                          "additionalProperties": false,
                          "properties": {
                            "policies": {
                              "items": {
                                "type": "object"
                              },
                              "type": "array"
                            },
                            "selectPolicy": {
                              "type": "string"
                            },
                            "stabilizationWindowSeconds": {
                              "type": "integer"
                            }
                          },
                          "type": "object"
                        },
                        "targetCPUUtilizationPercentage": {
                          "type": "integer"
                        },
                        "targetMemoryUtilizationPercentage": {
                          "type": "integer"
                        }
