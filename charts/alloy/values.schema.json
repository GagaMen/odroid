                      "additionalProperties": false,
                      "properties": {
                        "enabled": {
                          "type": "boolean"
                        },
                        "recommenders": {
                          "items": {
                            "type": "object"
                          },
                          "type": "array"
                        },
                        "resourcePolicy": {
                          "type": "object"
                        },
                        "updatePolicy": {
                          "type": "object"
                        }
                      },
                      "type": "object"
                    }
