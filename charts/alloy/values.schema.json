                },
                "annotations": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "description": "Annotations to add to the created service account",
                  "type": "object"
                },
                "automountServiceAccountToken": {
                  "description": "Whether the Alloy pod should automatically mount the service account token",
                  "type": "boolean"
                },
                "create": {
                  "description": "Whether to create a service account",
                  "type": "boolean"
                },
                "name": {
                  "description": "Name of the existing service account to use when create is false",
                  "type": "string"
                }
              },
              "type": "object"
            },
            "serviceMonitor": {
              "additionalProperties": false,
              "properties": {
                "additionalLabels": {
                  "additionalProperties": {
                    "type": "string"
                  },
