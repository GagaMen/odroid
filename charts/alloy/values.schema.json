                      "type": "object"
                    },
                    "maxReplicas": {
                      "minimum": 1,
                      "type": "integer"
                    },
                    "minReplicas": {
                      "minimum": 1,
                      "type": "integer"
                    },
                    "scaleDown": {
                      "additionalProperties": false,
                      "properties": {
                        "policies": {
                          "items": {
                            "type": "object"
                          },
                          "type": "array"
                        },
                        "selectPolicy": {
                          "type": "string"
                        },
                        "stabilizationWindowSeconds": {
                          "type": "integer"
                        }
                      },
                      "type": "object"
                    },
                    "scaleUp": {
                      "additionalProperties": false,
                      "properties": {
                        "policies": {
                          "items": {
                            "type": "object"
                          },
                          "type": "array"
                        },
                        "selectPolicy": {
                          "type": "string"
                        },
                        "stabilizationWindowSeconds": {
                          "type": "integer"
                        }
                      },
                      "type": "object"
                    },
                    "targetCPUUtilizationPercentage": {
                      "type": "integer"
                    },
                    "targetMemoryUtilizationPercentage": {
                      "type": "integer"
                    },
