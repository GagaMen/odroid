{
  "$ref": "#/definitions/Values",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "Values": {
      "additionalProperties": false,
      "properties": {
        "affinity": {
          "description": "Affinity rules for pod assignment",
          "type": "object"
        },
        "configMap": {
          "additionalProperties": false,
          "description": "ConfigMap configuration for ntfy server",
          "properties": {
            "data": {
              "additionalProperties": {
                "type": "string"
              },
              "description": "ConfigMap data entries",
              "type": "object"
            },
            "enable": {
              "description": "Enable ConfigMap creation",
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "enabled": {
          "description": "Enable/disable this chart (used by platform condition)",
          "type": "boolean"
        },
        "fullnameOverride": {
          "description": "Override the full release name",
          "type": "string"
        },
        "global": {
          "description": "Injected by Helm for sub-chart coordination",
          "type": "object"
        },
        "image": {
          "additionalProperties": false,
          "description": "Container image configuration",
          "properties": {
            "pullPolicy": {
              "description": "Image pull policy",
              "enum": [
                "Always",
                "IfNotPresent",
                "Never"
              ],
              "type": "string"
            },
            "repository": {
              "description": "Container image repository",
              "type": "string"
            },
            "tag": {
              "description": "Overrides the image tag whose default is the chart appVersion",
              "type": "string"
            }
          },
          "type": "object"
        },
        "ingress": {
          "additionalProperties": false,
          "description": "Ingress configuration",
          "properties": {
            "annotations": {
              "additionalProperties": {
                "type": "string"
              },
              "description": "Ingress annotations",
              "type": "object"
            },
            "className": {
              "description": "Ingress class name",
              "type": "string"
            },
            "enabled": {
              "description": "Enable ingress",
              "type": "boolean"
            },
            "hosts": {
              "description": "Ingress host rules",
              "items": {
                "additionalProperties": false,
                "properties": {
                  "host": {
                    "type": "string"
                  },
                  "paths": {
                    "items": {
                      "additionalProperties": false,
                      "properties": {
                        "path": {
                          "type": "string"
                        },
                        "pathType": {
                          "enum": [
                            "Prefix",
                            "Exact",
                            "ImplementationSpecific"
                          ],
                          "type": "string"
                        }
                      },
                      "type": "object"
                    },
                    "type": "array"
                  }
                },
                "type": "object"
              },
              "type": "array"
            },
            "tls": {
              "description": "Ingress TLS configuration",
              "items": {
                "additionalProperties": false,
                "properties": {
                  "hosts": {
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  },
                  "secretName": {
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "nameOverride": {
          "description": "Override the chart name",
          "type": "string"
        },
        "namespaceOverride": {
          "description": "Override the deployment namespace",
          "type": "string"
        },
        "nodeSelector": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Node selector for pod assignment",
          "type": "object"
        },
        "resources": {
          "additionalProperties": false,
          "description": "CPU/memory resource requests and limits",
          "properties": {
            "limits": {
              "additionalProperties": false,
              "description": "CPU/memory resource limits",
              "properties": {
                "cpu": {
                  "type": "string"
                },
                "memory": {
                  "type": "string"
                }
              },
              "type": "object"
            },
            "requests": {
              "additionalProperties": false,
              "description": "CPU/memory resource requests",
              "properties": {
                "cpu": {
                  "type": "string"
                },
                "memory": {
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          "type": "object"
        },
        "service": {
          "additionalProperties": false,
          "description": "Service configuration",
          "properties": {
            "port": {
              "description": "Service port number",
              "type": "integer"
            },
            "type": {
              "description": "Service type",
              "enum": [
                "ClusterIP",
                "NodePort",
                "LoadBalancer",
                "ExternalName"
              ],
              "type": "string"
            }
          },
          "type": "object"
        },
        "tolerations": {
          "description": "Tolerations for pod assignment",
          "items": {
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    }
  }
}